# ================================
#  Detectify v4 — Environment Variables
#  Copy to .env — NEVER commit .env!
# ================================

# ---- Required ----
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ---- Optional — Real Threat Intelligence ----
# Get from: https://console.cloud.google.com (Safe Browsing API)
GOOGLE_SAFE_BROWSING_KEY=your-google-key-here

# Get from: https://www.virustotal.com/gui/user/apikey
VIRUSTOTAL_KEY=your-virustotal-key-here

# ---- Database (Optional — MongoDB Atlas) ----
# Get from: https://cloud.mongodb.com (free tier available)
# Format: mongodb+srv://username:password@cluster.mongodb.net/detectify
MONGODB_URI=

# ---- Auth ----
# Change this to a long random string in production!
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
SCAN_LIMIT_MAX=20
